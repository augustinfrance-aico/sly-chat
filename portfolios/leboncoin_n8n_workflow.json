      "id": "is-new",
      "name": "Is New Listing?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1320, 0]
    },
    {
      "parameters": {
        "jsCode": "// Qualification Engine — keyword scoring\nconst item = $input.first().json;\nconst title = (item.title || '').toLowerCase();\nconst description = (item.description || '').toLowerCase();\nconst text = title + ' ' + description;\n\n// Negative keywords — reject\nconst negatives = ['accidenté', 'panne', 'pour pièces', 'hs', 'épave',\n  'non roulant', 'moteur hs', 'à réparer', 'crash', 'ne démarre pas',\n  'ne roule pas', 'accidentee', 'sinistre', 'epave'];\n\n// Positive keywords — boost score\nconst positives = ['bon état', 'très bon état', 'excellent état', 'ct ok',\n  'contrôle technique ok', 'faible km', 'première main', 'entretien suivi',\n  'carnet entretien', 'garage', 'révision faite', 'ct vierge'];\n\nlet score = 50; // Base score\nlet rejection_reasons = [];\n\n// Check negatives\nfor (const neg of negatives) {\n  if (text.includes(neg)) {\n    score -= 30;\n    rejection_reasons.push(neg);\n  }\n}\n\n// Check positives\nfor (const pos of positives) {\n  if (text.includes(pos)) {\n    score += 15;\n  }\n}\n\n// Clamp score\nscore = Math.max(0, Math.min(100, score));\n\nconst qualified = score >= 40;\n\nreturn [{\n  json: {\n    ...item,\n    qualification_score: score,\n    qualified: qualified,\n    rejection_reasons: rejection_reasons.join(', ') || 'none',\n    qualified_at: new Date().toISOString()\n  }\n}];"
      },
      "id": "qualify-listing",
      "name": "Qualification Engine",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1540, -100]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "is-qualified",
              "leftValue": "={{ $json.qualified }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "is-qualified",
      "name": "Qualified?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1760, -100]
    },
    {
      "parameters": {
        "jsCode": "// Generate personalized first message\nconst item = $input.first().json;\nconst vehicle = item.title || 'votre véhicule';\nconst price = item.price ? `${item.price}€` : '';\nconst city = item.city || '';\n\nconst templates = [\n  `Bonjour, je suis intéressé par votre ${vehicle}${price ? ` à ${price}` : ''}. Est-il toujours disponible ? Serait-il possible d'échanger par téléphone ?`,\n  `Bonjour, votre annonce pour ${vehicle} m'intéresse beaucoup${city ? `, je suis dans la région de ${city}` : ''}. Pourriez-vous me rappeler pour en discuter ?`,\n  `Bonjour, je recherche exactement ce type de véhicule. Votre ${vehicle} est-il toujours en vente ? Je préfère échanger par téléphone si possible.`\n];\n\n// Random template selection\nconst message = templates[Math.floor(Math.random() * templates.length)];\n\nreturn [{\n  json: {\n    ...item,\n    outbound_message: message,\n    message_sent_at: null,\n    status: 'ready_to_send'\n  }\n}];"
      },
      "id": "generate-message",
      "name": "Generate Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1980, -200]
    },
    {
      "parameters": {
        "jsCode": "// Simulate wait for human-like behavior\nconst randomDelay = Math.floor(Math.random() * (15 - 2 + 1) + 2);\n// In production: use n8n Wait node or external queue\n\nconst item = $input.first().json;\n\nreturn [{\n  json: {\n    ...item,\n    delay_minutes: randomDelay,\n    note: 'In production: Playwright sends this message via Leboncoin messaging UI after delay'\n  }\n}];"
      },
      "id": "human-delay",
      "name": "Human Delay Logic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2200, -200]
    },
    {
      "parameters": {
        "jsCode": "// Phone number extraction from seller replies\nconst item = $input.first().json;\nconst reply = (item.seller_reply || '').replace(/\\s+/g, ' ');\n\n// French phone patterns\nconst patterns = [\n  /0[67][\\s.-]?\\d{2}[\\s.-]?\\d{2}[\\s.-]?\\d{2}[\\s.-]?\\d{2}/g,\n  /\\+33[\\s.-]?[67][\\s.-]?\\d{2}[\\s.-]?\\d{2}[\\s.-]?\\d{2}[\\s.-]?\\d{2}/g,\n  /zero\\s*six[\\s.-]?\\d{2}[\\s.-]?\\d{2}[\\s.-]?\\d{2}[\\s.-]?\\d{2}/gi,\n  /zero\\s*sept[\\s.-]?\\d{2}[\\s.-]?\\d{2}[\\s.-]?\\d{2}[\\s.-]?\\d{2}/gi\n];\n\nlet phone = null;\nfor (const pattern of patterns) {\n  const match = reply.match(pattern);\n  if (match) {\n    // Clean the number\n    phone = match[0].replace(/[\\s.-]/g, '');\n    if (phone.startsWith('+33')) {\n      phone = '0' + phone.slice(3);\n    }\n    break;\n  }\n}\n\nconst phone_found = phone !== null;\n\nreturn [{\n  json: {\n    ...item,\n    phone_number: phone,\n    phone_found: phone_found,\n    extraction_method: phone_found ? 'regex' : 'none',\n    extracted_at: phone_found ? new Date().toISOString() : null\n  }\n}];"
      },
      "id": "extract-phone",
      "name": "Extract Phone Number",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2420, -200]
    },
