      "id": "fetch-listings",
      "name": "Fetch Leboncoin Listings",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 0]
    },
    {
      "parameters": {
        "jsCode": "// Parse HTML response and extract listing data\nconst html = $input.first().json.data;\nconst listings = [];\n\n// Extract listing blocks from Leboncoin HTML\n// Note: Adapt selectors based on current Leboncoin DOM structure\nconst listingRegex = /\"list_id\":(\\d+),.*?\"subject\":\"(.*?)\",.*?\"price\":\\[(\\d+)\\],.*?\"url\":\"(.*?)\",.*?\"city\":\"(.*?)\"/g;\n\nlet match;\nwhile ((match = listingRegex.exec(html)) !== null) {\n  listings.push({\n    listing_id: match[1],\n    title: match[2],\n    price: parseInt(match[3]),\n    url: `https://www.leboncoin.fr${match[4]}`,\n    city: match[5],\n    scraped_at: new Date().toISOString()\n  });\n}\n\nreturn listings.map(l => ({ json: l }));"
      },
      "id": "parse-listings",
      "name": "Parse Listings",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 0]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {
          "reset": false
        }
      },
      "id": "split-batches",
      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [880, 0]
    },
    {
      "parameters": {
        "operation": "lookup",
        "documentId": {
          "__rl": true,
          "mode": "list",
          "value": ""
        },
