      "id": "check-duplicate",
      "name": "Check Duplicate",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1100, 0],
      "notes": "Connect your Google Sheet ID — sheet 'processed_listings' with column 'listing_id'"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "new-listing",
              "leftValue": "={{ $json.listing_id }}",
