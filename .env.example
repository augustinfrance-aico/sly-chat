# ============================================================
# .env.example — SLY / Cooper Building
# Copier en .env et remplir avec vos vraies clés
# ============================================================

# === HUNTER.IO (Free: 25 searches/month) ===
HUNTER_API_KEY=your_hunter_api_key_here

# === GOOGLE ===
GOOGLE_CUSTOM_SEARCH_KEY=your_google_search_key
GOOGLE_CREDENTIALS_PATH=/path/to/service-account-credentials.json

# === N8N (Cloud) ===
N8N_URL=https://your-instance.app.n8n.cloud/
N8N_API_KEY=your_n8n_api_key

# === ANTHROPIC (Claude API) ===
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# === GEMINI (Free) ===
GEMINI_API_KEY=your_gemini_key

# === GROQ (Free) ===
GROQ_API_KEY=gsk_xxx

# === N8N Railway (secondary instance) ===
N8N_RAILWAY_URL=https://your-n8n-railway.up.railway.app
N8N_RAILWAY_API_KEY=your_n8n_railway_key

# === SLY Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# === MEM0 (Free: 10K memories/month) ===
MEM0_API_KEY=your_mem0_key

# === ELEVENLABS TTS (Free: 10K chars/month) ===
ELEVENLABS_API_KEY=sk_xxx

# === FISHAUDIO TTS (Plus: 200 min/month, ~11$/mo) ===
FISHAUDIO_API_KEY=your_fishaudio_key

# === PADELSHOT (optional) ===
PADELSHOT_EMAIL=your_email
PADELSHOT_PASSWORD=your_password
CHARLOTTE_TELEGRAM_CHAT_ID=optional_chat_id
